# Delivery-Risk MLOps — environment template.
# Copy to `.env` and adjust. `.env` is gitignored; this template is committed.
# docker-compose.yaml already sets these for the containers via service names; this
# file documents the variables and is handy when running pieces directly on the host.
#
# Model resolution order (the service never hard-fails on startup):
#   1. MLflow registry  models:/${MODEL_NAME}/${MODEL_STAGE}
#   2. local joblib      ${MODEL_PATH}   (used only if the registry has no such model)
#   3. bounded arithmetic baseline

# ─────────────────────────────────────────────────────────────────────────────
# Model source
# ─────────────────────────────────────────────────────────────────────────────
# In the compose stack this is the mlflow service; on the host use 127.0.0.1.
MLFLOW_TRACKING_URI=http://mlflow:5312
MODEL_NAME=delivery-risk
MODEL_STAGE=Staging

# Optional local joblib fallback. Point it at a trained pipeline .joblib to serve a
# real model before anything is registered in MLflow. Leave unset to skip.
# MODEL_PATH=/models/model.joblib

LOAD_MODEL_ON_STARTUP=true

# Keep MLflow probes short so an unreachable tracking server never blocks startup.
MLFLOW_HTTP_REQUEST_TIMEOUT=3
MLFLOW_HTTP_REQUEST_MAX_RETRIES=0
MLFLOW_PROBE_TIMEOUT=1.5

# ─────────────────────────────────────────────────────────────────────────────
# Risk policy (late-delivery probability -> risk_level)
# ─────────────────────────────────────────────────────────────────────────────
HIGH_RISK_THRESHOLD=0.55
MEDIUM_RISK_THRESHOLD=0.25

# ─────────────────────────────────────────────────────────────────────────────
# Logging (json for Loki/Grafana ingestion, text for local reading)
# ─────────────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json

# ─────────────────────────────────────────────────────────────────────────────
# Database (pipeline/* + the API's monitoring reads)
# ─────────────────────────────────────────────────────────────────────────────
# Either a full DATABASE_URL, or the discrete POSTGRES_* parts below.
# DATABASE_URL=postgresql+psycopg2://delivery:delivery@postgres:5432/delivery_risk
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=delivery
POSTGRES_PASSWORD=delivery
POSTGRES_DB=delivery_risk

# Where the raw Olist CSVs live. Defaults to the committed synthetic sample.
# RAW_DATA_DIR=sample_data                 # or olist_data/olist_data for the full dataset
#
# Per-layer (medallion) schemas. All default to PG_SCHEMA_DEFAULT (public), so a
# single-schema DB needs none of these; set them to split the layers apart:
#   RAW_SCHEMA=raw
#   STAGING_SCHEMA=staging
#   FEATURES_SCHEMA=features
#   PREDICTIONS_SCHEMA=predictions
#   MONITORING_SCHEMA=monitoring
# PG_SCHEMA_DEFAULT=public
