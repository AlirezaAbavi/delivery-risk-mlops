# MLOps Delivery — FastAPI delivery-risk service.
# Copy to `.env` and adjust. `.env` is gitignored; this template is committed.
# Only the variables the API (app/*) actually reads are listed here.
#
# Model resolution order (the service never hard-fails on startup):
#   1. MLflow registry  models:/${MODEL_NAME}/${MODEL_STAGE}
#   2. local joblib      ${MODEL_PATH}   (used only if the registry has no such model)
#   3. bounded arithmetic baseline

# ─────────────────────────────────────────────────────────────────────────────
# Model source
# ─────────────────────────────────────────────────────────────────────────────
# Delivery MLflow (per README it is available at 127.0.0.1:5312, port-forwarded
# locally; the same port is reachable on the server).
MLFLOW_TRACKING_URI=http://127.0.0.1:5312
MODEL_NAME=delivery-risk
MODEL_STAGE=Staging

# Optional local joblib fallback. Point it at a trained pipeline .pkl to serve a
# real model before anything is registered in MLflow. Leave unset to skip.
# MODEL_PATH=/models/pipeline.pkl

LOAD_MODEL_ON_STARTUP=true

# Keep MLflow probes short so an unreachable tracking server never blocks startup.
MLFLOW_HTTP_REQUEST_TIMEOUT=3
MLFLOW_HTTP_REQUEST_MAX_RETRIES=0
MLFLOW_PROBE_TIMEOUT=1.5

# ─────────────────────────────────────────────────────────────────────────────
# Risk policy (late-delivery probability -> risk_level)
# ─────────────────────────────────────────────────────────────────────────────
HIGH_RISK_THRESHOLD=0.55
MEDIUM_RISK_THRESHOLD=0.25

# ─────────────────────────────────────────────────────────────────────────────
# Logging (json for Loki/Grafana ingestion, text for local reading)
# ─────────────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json

# ─────────────────────────────────────────────────────────────────────────────
# Pipeline: database + medallion schema layout (pipeline/* only, not the API)
# ─────────────────────────────────────────────────────────────────────────────
# DATABASE_URL=postgresql+psycopg2://USER:PASS@HOST:PORT/DBNAME
# RAW_DATA_DIR points at the Olist CSVs (server: /home/delivery/olist_data).
# RAW_DATA_DIR=olist_data/olist_data
#
# Per-layer schemas. All default to PG_SCHEMA_DEFAULT (public) so a single-schema
# local DB needs none of these; the server's multi-schema DB sets them explicitly:
#   RAW_SCHEMA=raw
#   STAGING_SCHEMA=staging
#   FEATURES_SCHEMA=features
#   PREDICTIONS_SCHEMA=predictions
#   MONITORING_SCHEMA=monitoring
# PG_SCHEMA_DEFAULT=public
