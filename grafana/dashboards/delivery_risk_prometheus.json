{
  "uid": "delivery-risk",
  "title": "Delivery-Risk Service (Prometheus)",
  "description": "Service health + model output for the delivery-risk API, read from the local Prometheus. Every query is pinned to $instance. Auto-provisioned into Grafana on docker compose up.",
  "tags": ["delivery-risk", "mlops", "prometheus", "cd", "demo"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 4,
  "editable": true,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "instance",
        "label": "API instance",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(up{job=\"delivery_risk_api\"}, instance)",
        "query": { "query": "label_values(up{job=\"delivery_risk_api\"}, instance)", "refId": "instance" },
        "current": { "text": "api:8112", "value": "api:8112" },
        "refresh": 1,
        "includeAll": false,
        "multi": false,
        "sort": 1
      }
    ]
  },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "API up",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "up{job=\"delivery_risk_api\", instance=\"$instance\"}", "instant": true, "legendFormat": "up" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short", "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "background", "graphMode": "none", "textMode": "value" }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Model loaded (1=real model, 0=baseline)",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "delivery_model_loaded{instance=\"$instance\"}", "instant": true, "legendFormat": "model_loaded" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short", "mappings": [
            { "type": "value", "options": { "0": { "text": "baseline", "color": "orange" }, "1": { "text": "model", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "orange", "value": null }, { "color": "green", "value": 1 } ] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "background", "graphMode": "none", "textMode": "value" }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Total predictions",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(delivery_predictions_total{instance=\"$instance\"})", "instant": true, "legendFormat": "predictions" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "blue" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "area", "textMode": "value" }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Scoring errors (degraded to baseline)",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(delivery_prediction_errors_total{instance=\"$instance\"})", "instant": true, "legendFormat": "errors" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] } },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "none", "textMode": "value" }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Request rate by endpoint (req/s)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (endpoint) (rate(delivery_http_requests_total{instance=\"$instance\"}[5m]))", "legendFormat": "{{endpoint}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Error rate (HTTP >= 400, err/s)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (status) (rate(delivery_http_errors_total{instance=\"$instance\"}[5m]))", "legendFormat": "HTTP {{status}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never" }, "color": { "mode": "fixed", "fixedColor": "red" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Prediction latency (p50 / p95 / p99, seconds)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum by (le) (rate(delivery_prediction_latency_seconds_bucket{instance=\"$instance\"}[5m])))", "legendFormat": "p50" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(delivery_prediction_latency_seconds_bucket{instance=\"$instance\"}[5m])))", "legendFormat": "p95" },
        { "refId": "C", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum by (le) (rate(delivery_prediction_latency_seconds_bucket{instance=\"$instance\"}[5m])))", "legendFormat": "p99" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 5, "showPoints": "never" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 8,
      "type": "piechart",
      "title": "Risk-level distribution (model output)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (risk_level) (delivery_predictions_total{instance=\"$instance\"})", "instant": true, "legendFormat": "{{risk_level}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "hideFrom": { "legend": false, "tooltip": false, "viz": false } },
          "color": { "mode": "palette-classic" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "low" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } } ] },
          { "matcher": { "id": "byName", "options": "medium" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } } ] },
          { "matcher": { "id": "byName", "options": "high" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } } ] }
        ]
      },
      "options": { "pieType": "donut", "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] }, "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Predictions by risk level over time (pred/s)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (risk_level) (rate(delivery_predictions_total{instance=\"$instance\"}[5m]))", "legendFormat": "{{risk_level}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 20, "stacking": { "mode": "normal", "group": "A" }, "showPoints": "never" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "low" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } } ] },
          { "matcher": { "id": "byName", "options": "medium" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } } ] },
          { "matcher": { "id": "byName", "options": "high" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } } ] }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 20,
      "type": "row",
      "title": "Deployment (CD hook)",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 28 },
      "panels": []
    },
    {
      "id": 21,
      "type": "stat",
      "title": "Last deploy status",
      "description": "1 if the most recent CD-hook deploy succeeded (tests passed + actions ok), 0 otherwise. Sourced from the API's delivery_deploy_last_status gauge, which reads ~/deploy-runs.jsonl.",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 29 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "delivery_deploy_last_status{instance=\"$instance\"}", "instant": true, "legendFormat": "status" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short", "mappings": [
            { "type": "value", "options": { "0": { "text": "FAILED", "color": "red" }, "1": { "text": "OK", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "background", "graphMode": "none", "textMode": "value" }
    },
    {
      "id": 22,
      "type": "stat",
      "title": "Time since last deploy",
      "description": "Age of the most recent recorded deploy.",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 29 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "time() - delivery_deploy_last_timestamp_seconds{instance=\"$instance\"}", "instant": true, "legendFormat": "age" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "fixed", "fixedColor": "blue" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "none", "textMode": "value" }
    },
    {
      "id": 23,
      "type": "stat",
      "title": "Last deploy duration",
      "description": "Wall-clock time the last deploy (fetch → test gate → restart/trigger/import) took.",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 29 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "delivery_deploy_last_duration_seconds{instance=\"$instance\"}", "instant": true, "legendFormat": "duration" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "fixed", "fixedColor": "purple" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "none", "textMode": "value" }
    },
    {
      "id": 24,
      "type": "stat",
      "title": "Deploys recorded",
      "description": "Number of deploy attempts in the current run-log window (last ~20).",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 29 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "delivery_deploy_runs_total{instance=\"$instance\"}", "instant": true, "legendFormat": "runs" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "blue" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "none", "textMode": "value" }
    },
    {
      "id": 26,
      "type": "stat",
      "title": "Retrain succeeded",
      "description": "1 if the last deploy's Airflow retrain finished successfully, 0 otherwise (failed / still running / no retrain queued). See the 'Last retrain state' table for the exact state. Sourced from delivery_deploy_last_retrain_status, reconciled async by ci/watch_dag.py.",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 33 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "delivery_deploy_last_retrain_status{instance=\"$instance\"}", "instant": true, "legendFormat": "retrain" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short", "mappings": [
            { "type": "value", "options": { "0": { "text": "no / pending", "color": "orange" }, "1": { "text": "SUCCESS", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "orange", "value": null }, { "color": "green", "value": 1 } ] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "background", "graphMode": "none", "textMode": "value" }
    },
    {
      "id": 25,
      "type": "table",
      "title": "Last deploy commit",
      "description": "Commit SHA and status of the last deploy, carried as labels on delivery_deploy_last_commit_info. Full history + changed paths are at the API's /deploy-status endpoint.",
      "gridPos": { "h": 5, "w": 9, "x": 6, "y": 33 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "delivery_deploy_last_commit_info{instance=\"$instance\"}", "instant": true, "format": "table" }
      ],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true, "Value": true, "__name__": true, "job": true }, "renameByName": { "commit": "Commit", "status": "Status", "instance": "Instance" } } }
      ],
      "fieldConfig": { "defaults": { "custom": { "align": "left" } }, "overrides": [] },
      "options": { "showHeader": true }
    },
    {
      "id": 27,
      "type": "table",
      "title": "Last retrain state",
      "description": "State (running / success / failed / timeout / none) and Airflow run id of the retrain the last deploy queued, carried as labels on delivery_deploy_last_retrain_info. Reconciled asynchronously so it lags the deploy while the DAG runs.",
      "gridPos": { "h": 5, "w": 9, "x": 15, "y": 33 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "delivery_deploy_last_retrain_info{instance=\"$instance\"}", "instant": true, "format": "table" }
      ],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true, "Value": true, "__name__": true, "job": true, "instance": true }, "renameByName": { "state": "State", "run_id": "Airflow run" } } }
      ],
      "fieldConfig": { "defaults": { "custom": { "align": "left" } }, "overrides": [] },
      "options": { "showHeader": true }
    }
  ]
}
